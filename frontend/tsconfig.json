{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["jest", "@testing-library/jest-dom"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["src",
    "tests"],
  "exclude": ["node_modules", "dist"]
}
