{
  "name": "messanger",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:backend": "npm run dev --workspace=@messanger/backend",
    "dev:frontend": "npm run dev --workspace=@messanger/frontend",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "build:backend": "npm run build --workspace=@messanger/backend",
    "build:frontend": "npm run build --workspace=@messanger/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "test:backend": "npm test --workspace=@messanger/backend",
    "test:frontend": "npm test --workspace=@messanger/frontend",
    "test:e2e": "npm run test:e2e --workspace=@messanger/backend",
    "test": "npm-run-all --parallel test:backend test:frontend test:e2e",
    "typecheck": "tsc -b backend frontend",
    "test:coverage:backend": "npm run test:coverage --workspace=@messanger/backend",
    "test:coverage:frontend": "npm run test:coverage --workspace=@messanger/frontend",
    "test:coverage": "npm-run-all --parallel test:coverage:backend test:coverage:frontend",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.64.0"
  }
}
